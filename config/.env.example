# Fact Fusion Automation - Environment Variables
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM API Keys (Choose one: Gemini or OpenAI)
# ===========================================

# Google Gemini API (FREE tier: 60 requests/minute)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API (Optional, if not using Gemini)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# YouTube OAuth2 (Required for auto-upload)
# ===========================================
# Get credentials: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
# OAuth 2.0 Client ID → Download JSON → Save as ~/.config/google/client_secret.json

# ===========================================
# TTS Settings (Piper = FREE, Edge = Azure paid)
# ===========================================
TTS_PROVIDER=piper
PIPER_VOICE=en_US-lessac-medium
PIPER_LANGUAGE=en

# Edge TTS (Azure) - Optional, if not using Piper
# TTS_PROVIDER=edge_tts
# EDGE_VOICE=en-US-GuyNeural
# EDGE_RATE=1.0
# EDGE_VOLUME=1.0

# ===========================================
# Google Trends Settings
# ===========================================
TRENDS_COUNTRY=US
TRENDS_CATEGORY=all
TRENDS_REFRESH_INTERVAL=3600

# ===========================================
# Video Output Settings
# ===========================================
VIDEO_ORIENTATION=portrait
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_BITRATE=5000

# ===========================================
# Batch Processing Settings
# ===========================================
BATCH_MAX_VIDEOS=100
BATCH_PARALLEL_JOBS=4
BATCH_RETRY_FAILED=true
BATCH_MAX_RETRIES=3

# ===========================================
# Web UI Settings (Optional)
# ===========================================
WEB_UI_ENABLED=true
WEB_UI_PORT=8000
WEB_UI_HOST=0.0.0.0

# ===========================================
# Logging Settings
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log